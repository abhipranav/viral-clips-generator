NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# Enable this only on your local laptop when you want Next.js
# to run yt-dlp and forward the finished file to the EC2 API.
NEXT_PUBLIC_LOCAL_YTDLP_ENABLED=false
LOCAL_YTDLP_ENABLED=false
YT_DLP_BIN=yt-dlp
