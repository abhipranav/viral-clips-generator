GEMINI_API_KEY=replace-me

# Low-memory defaults for a 4 GB EC2 instance
WHISPER_MODEL=tiny
MAX_PARALLEL_CLIPS=1
JOB_CONCURRENCY=1
MAX_CLIPS=5
GENERATE_CAPTIONS=false
REMOVE_SILENCE=true
PREFER_YOUTUBE_TRANSCRIPTS=false

SERVER_HOST=0.0.0.0
SERVER_PORT=3001
MAX_UPLOAD_SIZE_MB=2048

# Optional storage overrides for larger EBS mounts
# DATA_DIR=/mnt/jiang-clips/data
# OUTPUT_DIR=/mnt/jiang-clips/output
# UPLOADS_DIR=/mnt/jiang-clips/uploads
# CHECKPOINT_DB_PATH=/mnt/jiang-clips/data/checkpoints.db

OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
CLIP_SPEED=1.2
SILENCE_THRESHOLD_DB=-35
SILENCE_MIN_DURATION=0.8
